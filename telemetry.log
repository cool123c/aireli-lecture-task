-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":18,"operation":"replace","value":"import { PlatformAccessToken, PlatformUserCreateInput, PlatformUser } from '@enterprise-commerce/core/platform/types';\nimport axios from 'axios';\nimport jwt from 'jsonwebtoken';\n\nconst registerUser = async (input: PlatformUserCreateInput): Promise<Pick<PlatformUser, \"id\"> | undefined | null> => {\n  try {\n    const { data } = await axios.post('http://localhost:3001/register', input);\n    return data?.user ?? null;\n  } catch (error: any) {\n    if (error?.response?.status === 409) {\n      // Keep current modal behavior: null means user already exists.\n      return null;\n    }\n\n    throw error;\n  }\n};\n\nconst loginUser = async (input: PlatformUserCreateInput) => {\n  // ToDo: Implement the loginUser function (someone else is working on it)\n  const user = {id: null} // replace this line\n\n\n  // The following lines can be left unchanged because the output is expected to be a JWT token and an expiresAt value\n  const accessToken = jwt.sign({ id: user?.id }, process.env.JWT_SECRET || \"no_key_set\" as string, { expiresIn: '1h' });\n  const expiresAt = new Date(Date.now() + 3600 * 1000).toISOString(); // 3600 seconds = 1 hour\n  return { accessToken, expiresAt };\n};\n\nconst getUser = async (accessToken: string): Promise<PlatformUser | undefined | null> => {\n  try {\n    if(accessToken != \"\") {\n      const { data } = await axios.get('http://localhost:3001/me', {\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n        },\n      });\n\n      return data.user;\n    } else {\n      return null\n    }\n  } catch (error) {\n    console.error(error);\n    // Handle error\n    return null;\n  }\n};\n\nexport default {\n  registerUser,\n  loginUser,\n  getUser\n};","rangeOffset":"0","rangeLength":"1468","rangestart_line":"0","rangestart_character":"0","rangeend_line":"45","rangeend_character":"2"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentSaveEvent","eventTime":1773770524965,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":18,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"ActiveEditorChangeEvent","eventTime":1773770532700,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/app/actions/user.actions.ts","documentId":17,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"ActiveEditorChangeEvent","eventTime":1773770540509,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/storefrontClient.ts","documentId":19,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"ActiveEditorChangeEvent","eventTime":1773770541395,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/inte