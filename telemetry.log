ces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":10,"operation":"delete","value":"","rangeOffset":"258","rangeLength":"12","rangestart_line":"7","rangestart_character":"26","rangeend_line":"9","rangeend_character":"1"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentChangeEvent","eventTime":1773768409135,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":10,"operation":"add","value":"sync (\n  input: PlatformUserCreateInput\n): Promise<PlatformUser> => {\n  const db = await openDb();\n  try {\n    const hashedPassword = await bcrypt.hash(input.password, 10);\n\n    const result = await db.run(\n      `INSERT INTO users (email, password) VALUES (?, ?)`,\n      input.email,\n      hashedPassword\n    );\n\n    return {\n      id: String(result.lastID),\n      email: input.email,\n      password: hashedPassword,\n    };\n  } finally {\n    await db.close();\n  }\n};","rangeOffset":"258","rangeLength":"0","rangestart_line":"7","rangestart_character":"26","rangeend_line":"7","rangeend_character":"26"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentCloseEvent","eventTime":1773768450949,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/middleware/auth.middleware.ts","documentId":16,"operation":"close","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"ActiveEditorChangeEvent","eventTime":1773768452930,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299