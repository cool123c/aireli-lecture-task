296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":10,"operation":"add","value":"try {\n    const hashedPassword = await bcrypt.hash(input.password, 10);\n\n    const result = await db.run(\n      `INSERT INTO users (email, password) VALUES (?, ?)`,\n      input.email,\n      hashedPassword\n    );\n\n    return {\n      id: String(result.lastID), // DB id ist integer, PlatformUser.id ist string\n      email: input.email,\n      password: hashedPassword\n    };\n  } finally {\n    await db.close();\n  }","rangeOffset":"381","rangeLength":"0","rangestart_line":"10","rangestart_character":"2","rangeend_line":"10","rangeend_character":"2"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentChangeEvent","eventTime":1773768846365,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":10,"operation":"add","value":";","rangeOffset":"795","rangeLength":"0","rangestart_line":"28","rangestart_character":"1","rangeend_line":"28","rangeend_character":"1"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"ActiveEditorChangeEvent","eventTime":1773768850740,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":10,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentChangeEvent","eventTime":1773768907745,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555c