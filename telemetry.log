":"DocumentChangeEvent","eventTime":1773769105815,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":15,"operation":"add","value":"const createdUser = await createUser({ email, password });\n\n    const token = jwt.sign(\n      { id: createdUser.id },\n      process.env.JWT_SECRET || \"no_key_set\",\n      { expiresIn: \"1d\" }\n    );\n\n    res.status(201).json({\n      user: {\n        id: createdUser.id,\n        email: createdUser.email\n      },\n      token\n    });\n  } catch (error: any) {\n    if (error?.code === 'SQLITE_CONSTRAINT') {\n      res.status(409).json({ message: 'Email already exists' });\n      return;\n    }\n\n    res.status(500).json({ message: 'Registration failed' });\n  }","rangeOffset":"320","rangeLength":"0","rangestart_line":"7","rangestart_character":"2","rangeend_line":"7","rangeend_character":"2"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentSaveEvent","eventTime":1773769114910,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":15,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentChangeEvent","eventTime":1773769177235,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":15,"operation":"add","value":"\n  ","rangeOffset":"277","rangeLe