= req.body;\n\n    if (typeof email !== 'string' || typeof password !== 'string' || !email || !password) {\n      res.status(400).json({ message: 'Email and password are required' });\n      return;\n    }\n\n    const createdUser = await createUser({ email, password });\n\n    const token = jwt.sign(\n      { id: createdUser.id },\n      process.env.JWT_SECRET || \"no_key_set\",\n      { expiresIn: \"1d\" }\n    );\n\n    res.status(201).json({\n      user: {\n        id: createdUser.id,\n        email: createdUser.email\n      },\n      token\n    });\n  } catch (error: any) {\n    if (error?.code === 'SQLITE_CONSTRAINT') {\n      res.status(409).json({ message: 'Email already exists' });\n      return;\n    }\n\n    res.status(500).json({ message: 'Registration failed' });\n  }\n};","rangeOffset":"0","rangeLength":"924","rangestart_line":"0","rangestart_character":"0","rangeend_line":"36","rangeend_character":"2"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentSaveEvent","eventTime":1773770320301,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":15,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentChangeEvent","eventTime":1773770326171,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/server.ts","documentId":23,"operation":"replace","value":"import app from './app';\nimport initializeDb from './db/init';\n\nconst PORT = process.env.PORT || 3001;\n\nasync function startServer() {\n  try {\n    console.log('Initializing database...');\n    await initializeDb();\n\n    app.listen(PORT, () => {\n      console.log(`Server is running on port ${PORT}`);\n    });\n  } catch (err) {\n    console.error('Failed to initialize database', err);\n    process.exit(1);\n  }\n}\n\nstartServer();","rangeOffset":"0","rangeLength":"425","rangestart_line":"0","rangestart_character":"0","rangeend_line":"14","rangeend_character":"3"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"DocumentSaveEvent","eventTime":1773770326389,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/server.ts","documentId":23,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"WindowStateChangeEvent","eventTime":1773770336340,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"WindowStateChangeEvent","eventTime":1773770336866,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9610e3b5a7bb482422157378296ed7a62b8952f87299c40555cda546170c64","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"vigilant-zebra-x55574vw6x9v2pwrp","eventName":"WindowStateChangeEvent","eventTime":1773770337509,"sessionId":"8fb4b1cc-3c34-4980-919c-283995891c601773766898489","machineId":"cc9